{
    "job_type": "agentkd_rubrics_filter",
    "dataset": {
        "labeled_path": "data/tool_use_training_data.json"
    },
    "inference": {
        "step_models": {
            "RubricsAgent": {
                "model_name": "Qwen3-235B-A22B-Instruct-2507",
                "max_tokens": 10240,
                "temperature": 0.3,
                "solution_top_k": 3
            }
        },
        "processing": {
            "max_workers": 16,
            "max_tasks": null
        },
        "logging": {
            "already_processed_path": "logs/rubrics_processed.jsonl"
        },
        "paths": {
            "solution_path": "logs/solve_output/"
        },
        "api_configs": {
            "Qwen3-235B-A22B-Instruct-2507": {
                "api_base": "YOUR_QWEN3_API_BASE_ENV_VAR",
                "api_key_env": "YOUR_QWEN3_API_KEY_ENV_VAR"
            },
            "default": {
                "api_base": "http://localhost:8000/v1",
                "api_key_env": "EMPTY"
            }
        }
    }
}
